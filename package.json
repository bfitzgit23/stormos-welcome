{
  "name": "stormos-welcome",
  "version": "2.0.0",
  "description": "Modern welcome and software center for StormOS",
  "main": "main.js",
  "author": {
    "name": "Bennji",
    "email": "linuxstormos@gmail.com"
  },
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "dist:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "com.stormos.welcome",
    "productName": "StormOS Welcome",
    "directories": {
      "output": "dist"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": ["x64"]
        },
        {
          "target": "pacman",
          "arch": ["x64"]
        },
        {
          "target": "deb",
          "arch": ["x64"]
        }
      ],
      "category": "System",
      "maintainer": "StormOS Team <stormos@example.com>",
      "desktop": {
        "StartupNotify": true,
        "Categories": "System;Settings;"
      }
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer.js",
      "styles.css",
      "index.html",
      "package.json",
      "build/**/*"
    ]
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.6.4"
  }
}
