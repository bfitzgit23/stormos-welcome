def is_live_session() -> bool:
    """Check if running in live ISO environment."""
    for marker in LIVE_MARKERS:
        if Path(marker).exists():
            return True
    return False


def find_terminal() -> Optional[str]:
    """Find available terminal emulator."""
    terminals = ["xfce4-terminal", "xterm", "gnome-terminal", "konsole"]
    for term in terminals:
        if shutil.which(term):
            return term
    return None


def run_command(cmd: List[str], title: str = "StormOS", hold: bool = True):
    """Run a command in terminal or with pkexec."""
    # Use pkexec for sudo commands
    if cmd[0] == "sudo" and shutil.which("pkexec"):
        pkexec_cmd = ["pkexec"] + cmd[1:]
        try:
            subprocess.Popen(pkexec_cmd, start_new_session=True)
            return True
        except Exception:
            pass
    
    # Fallback to terminal
    term = find_terminal()
    if not term:
        QMessageBox.warning(None, "Terminal Error", 
                           "No terminal found. Install xfce4-terminal")
        return False
    
    cmd_str = " ".join(f'"{arg}"' if " " in arg else arg for arg in cmd)
    if hold:
        shell_cmd = f'bash -c "{cmd_str}; echo; read -p \'Press Enter to close...\'"'
    else:
        shell_cmd = f'bash -c "{cmd_str}"'
    
    term_name = os.path.basename(term)
    if term_name == "xfce4-terminal":
        args = [term, "--disable-server", "--title", title, "-e", shell_cmd]
    else:
        args = [term, "-title", title, "-e", shell_cmd]
    
    subprocess.Popen(args, start_new_session=True)
    return True


def run_capture(cmd: List[str]) -> tuple:
    """Run command and capture output."""
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, timeout=30)
        return result.returncode, result.stdout, result.stderr
    except Exception as e:
        return 1, "", str(e)


