class PackageBackend:
    def search(self, query: str) -> List[Dict]:
        raise NotImplementedError
    
    def get_installed(self) -> List[Dict]:
        raise NotImplementedError
    
    def install(self, pkg: str):
        raise NotImplementedError
    
    def remove(self, pkg: str):
        raise NotImplementedError


class PacmanBackend(PackageBackend):
    def search(self, query: str) -> List[Dict]:
        rc, out, _ = run_capture(["pacman", "-Ss", query])
        if rc != 0:
            return []
        
        packages = []
        lines = out.split('\n')
        i = 0
        while i < len(lines):
            line = lines[i].strip()
            if line and not line.startswith(' '):
                parts = line.split()
                if len(parts) >= 3:
                    name = parts[1] if '/' in parts[0] else parts[0].split('/')[-1]
                    version = parts[2] if len(parts) > 2 else ''
                    desc = lines[i+1].strip() if i+1 < len(lines) else ''
                    packages.append({
                        'name': name,
                        'version': version,
                        'description': desc,
                        'source': 'pacman',
                        'installed': 'installed' in line.lower()
                    })
            i += 1
        return packages
    
    def get_installed(self) -> List[Dict]:
        rc, out, _ = run_capture(["pacman", "-Q"])
        if rc != 0:
            return []
        
        packages = []
        for line in out.split('\n'):
            if line.strip():
                parts = line.split()
                if len(parts) >= 2:
                    packages.append({
                        'name': parts[0],
                        'version': parts[1],
                        'description': '',
                        'source': 'pacman',
                        'installed': True
                    })
        return packages
    
    def install(self, pkg: str):
        run_command(["sudo", "pacman", "-S", "--noconfirm", pkg])
    
    def remove(self, pkg: str):
        run_command(["sudo", "pacman", "-Rns", pkg])


class YayBackend(PackageBackend):
    def search(self, query: str) -> List[Dict]:
        if not shutil.which("yay"):
            return []
        
        rc, out, _ = run_capture(["yay", "-Ss", query])
        if rc != 0:
            return []
        
        packages = []
        for line in out.split('\n'):
            if line.startswith('aur/'):
                parts = line.split()
                name = parts[0].split('/')[1]
                version = parts[1] if len(parts) > 1 else ''
                packages.append({
                    'name': name,
                    'version': version,
                    'description': '',
                    'source': 'aur',
                    'installed': 'Installed' in line
                })
        return packages
    
    def get_installed(self) -> List[Dict]:
        rc, out, _ = run_capture(["pacman", "-Qm"])
        if rc != 0:
            return []
        
        packages = []
        for line in out.split('\n'):
            if line.strip():
                parts = line.split()
                if len(parts) >= 2:
                    packages.append({
                        'name': parts[0],
                        'version': parts[1],
                        'description': '',
                        'source': 'aur',
                        'installed': True
                    })
        return packages
    
    def install(self, pkg: str):
        run_command(["yay", "-S", "--noconfirm", pkg])
    
    def remove(self, pkg: str):
        run_command(["yay", "-Rns", pkg])


